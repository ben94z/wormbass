<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>WORMBASS V5 — Self-Digging Acid Bass Engine</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Bebas+Neue&family=Rajdhani:wght@300;500;700&display=swap');

/* ═══ GLOBAL ═══════════════════════════════════════════════ */
:root{
  --bg:#030407;--panel:#070a10;--panel2:#0c0f18;--brd:#141c28;--brd2:#1c2838;
  --acc:#00ffaa;--acid:#c8ff00;--red:#ff2244;--ora:#ff8800;--blu:#44aaff;--pur:#aa44ff;
  --sub:#00ddff;--mid:#ffaa00;--top:#ff4488;
  --txt:#b0c0dc;--dim:#38485e;--bright:#e0eeff;
  --worm1:#4aff44;--worm2:#88ff22;--soil1:#2d1a08;--soil2:#1a0d04;
}
*{margin:0;padding:0;box-sizing:border-box;}
html,body{width:100%;height:100%;background:var(--bg);}
body{font-family:'Share Tech Mono',monospace;color:var(--txt);display:flex;flex-direction:column;overflow:hidden;}

/* ═══ SPLASH ════════════════════════════════════════════════ */
#splash{
  position:fixed;inset:0;z-index:9999;
  display:flex;flex-direction:column;align-items:center;justify-content:flex-end;
  padding-bottom:8vh;
  background:#000;
  overflow:hidden;
}
#splash-img{
  position:absolute;inset:0;width:100%;height:100%;
  object-fit:cover;object-position:center top;
  filter:brightness(.85) saturate(1.2);
}
#splash-overlay{
  position:absolute;inset:0;
  background:linear-gradient(180deg,transparent 30%,rgba(0,0,0,.55) 65%,rgba(0,0,0,.92) 100%);
}
#splash-vignette{
  position:absolute;inset:0;
  box-shadow:inset 0 0 120px rgba(0,0,0,.8);
}
#splash-scanlines{
  position:absolute;inset:0;
  background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,.06) 2px,rgba(0,0,0,.06) 4px);
  pointer-events:none;
}
#splash-flicker{
  position:absolute;inset:0;animation:flicker 8s infinite;pointer-events:none;
  background:radial-gradient(ellipse at 50% 60%,rgba(200,255,0,.04) 0%,transparent 70%);
}
@keyframes flicker{0%,100%{opacity:1}94%{opacity:1}95%{opacity:.7}96%{opacity:1}98%{opacity:.85}99%{opacity:1}}

.splash-content{position:relative;z-index:2;display:flex;flex-direction:column;align-items:center;gap:18px;}

.splash-tagline{
  font-family:'Bebas Neue',sans-serif;font-size:clamp(.75rem,2vw,1rem);
  letter-spacing:.35em;color:rgba(200,255,0,.85);
  text-transform:uppercase;text-align:center;
  animation:tagpulse 2.8s ease-in-out infinite;
}
@keyframes tagpulse{
  0%  {text-shadow:0 0 8px rgba(200,255,0,.3),0 0 20px rgba(200,255,0,.1);
       opacity:.55;letter-spacing:.34em;}
  30% {text-shadow:0 0 18px rgba(200,255,0,.8),0 0 40px rgba(200,255,0,.4),0 0 80px rgba(200,255,0,.15);
       opacity:.95;letter-spacing:.38em;}
  55% {text-shadow:0 0 10px rgba(200,255,0,.5),0 0 25px rgba(200,255,0,.2);
       opacity:.7;letter-spacing:.36em;}
  75% {text-shadow:0 0 22px rgba(200,255,0,.9),0 0 55px rgba(200,255,0,.5),0 0 100px rgba(200,255,0,.2);
       opacity:1;letter-spacing:.40em;}
  100%{text-shadow:0 0 8px rgba(200,255,0,.3),0 0 20px rgba(200,255,0,.1);
       opacity:.55;letter-spacing:.34em;}
}

.splash-made{
  font-family:'Share Tech Mono',monospace;font-size:clamp(.55rem,1.5vw,.75rem);
  letter-spacing:.2em;text-transform:uppercase;
  background:linear-gradient(90deg,
    rgba(255,255,255,.18) 0%,
    rgba(255,255,255,.18) 30%,
    rgba(200,255,0,.9)   48%,
    rgba(255,255,255,1)  52%,
    rgba(200,255,0,.9)   56%,
    rgba(255,255,255,.18) 72%,
    rgba(255,255,255,.18) 100%
  );
  background-size:300% 100%;
  -webkit-background-clip:text;
  background-clip:text;
  -webkit-text-fill-color:transparent;
  animation:shimmer-roll 7s cubic-bezier(.45,0,.55,1) infinite;
}
@keyframes shimmer-roll{
  0%,15%  {background-position:140% 0}
  45%,55% {background-position:0% 0}
  85%,100%{background-position:-120% 0}
}

/* WRIGGLE BUTTON */
#wriggle-btn{
  position:relative;cursor:pointer;
  font-family:'Bebas Neue',sans-serif;font-size:clamp(1.4rem,5vw,2.6rem);
  letter-spacing:.25em;text-transform:uppercase;
  color:#c8ff00;
  padding:16px 48px 14px;
  border:2px solid rgba(200,255,0,.5);
  background:rgba(0,0,0,.7);
  outline:none;
  transition:transform .1s;
  overflow:hidden;
  text-shadow:0 0 20px rgba(200,255,0,.8),0 0 60px rgba(200,255,0,.3);
  box-shadow:0 0 20px rgba(200,255,0,.15),inset 0 0 30px rgba(200,255,0,.04);
  animation:wrigglebob 2.5s ease-in-out infinite;
}
@keyframes wrigglebob{
  0%,100%{transform:translateY(0) rotate(-.3deg)}
  25%{transform:translateY(-4px) rotate(.4deg)}
  50%{transform:translateY(-2px) rotate(-.2deg)}
  75%{transform:translateY(-5px) rotate(.3deg)}
}
#wriggle-btn::before{
  content:'';position:absolute;inset:0;
  background:linear-gradient(90deg,transparent,rgba(200,255,0,.08),transparent);
  transform:translateX(-100%);transition:transform .5s;
}
#wriggle-btn:hover{
  animation:none;
  transform:scale(1.04) rotate(0deg)!important;
  border-color:var(--acid);
  color:#fff;
  text-shadow:0 0 30px #c8ff00,0 0 80px rgba(200,255,0,.6),0 0 120px rgba(200,255,0,.3);
  box-shadow:0 0 40px rgba(200,255,0,.5),0 0 80px rgba(200,255,0,.2),inset 0 0 40px rgba(200,255,0,.08);
}
#wriggle-btn:hover::before{transform:translateX(100%);}
#wriggle-btn:active{transform:scale(.97)!important;}

.wriggle-worms{
  position:absolute;inset:0;pointer-events:none;overflow:hidden;
}
.splash-worm{
  position:absolute;bottom:-8px;
  width:6px;height:22px;border-radius:50%;
  background:linear-gradient(180deg,var(--worm2),var(--worm1));
  animation:wormpeek 3s ease-in-out infinite;
  box-shadow:0 0 8px rgba(136,255,34,.6);
}
@keyframes wormpeek{
  0%,100%{transform:translateY(100%) scaleX(1)}
  40%,60%{transform:translateY(0%) scaleX(.8)}
}

/* Loading bar */
#splash-loader{
  width:200px;height:2px;background:rgba(255,255,255,.1);overflow:hidden;
}
#splash-loader-fill{
  height:100%;width:0%;background:var(--acid);
  box-shadow:0 0 8px var(--acid);
  animation:loadfill 1.8s ease-out forwards;
}
@keyframes loadfill{0%{width:0%}100%{width:100%}}

#splash.fade-out{animation:splashfade .6s ease-out forwards;}
@keyframes splashfade{0%{opacity:1;transform:scale(1)}100%{opacity:0;transform:scale(1.05)}}

/* ═══ MAIN APP ═══════════════════════════════════════════ */
#app{display:flex;flex-direction:column;height:100%;opacity:0;transition:opacity .5s;}
#app.visible{opacity:1;}

/* ── HEADER ── */
.hdr{
  display:flex;flex-direction:column;gap:0;
  padding:0;flex-shrink:0;
  background:rgba(7,10,16,.98);
  border-bottom:1px solid var(--brd);
}
.hdr-row1{
  display:flex;align-items:center;gap:5px;
  padding:5px 10px;
  flex-wrap:nowrap;overflow:hidden;
  min-height:40px;
}
.hdr-row2{
  display:flex;align-items:center;gap:8px;
  padding:4px 10px 5px;
  border-top:1px solid var(--brd);
  background:rgba(0,0,0,.25);
}
.hdr-scan{
  position:absolute;inset:0;pointer-events:none;
  background:linear-gradient(90deg,transparent,rgba(0,255,170,.03),transparent);
  animation:hscan 6s linear infinite;
}
@keyframes hscan{0%{transform:translateX(-100%)}100%{transform:translateX(100%)}}

.logo{font-family:'Bebas Neue',sans-serif;font-size:1.45rem;letter-spacing:.08em;line-height:1;flex-shrink:0;cursor:pointer;}
.logo-w{color:var(--acc);text-shadow:0 0 12px rgba(0,255,170,.6);}
.logo-b{color:var(--acid);text-shadow:0 0 12px rgba(200,255,0,.5);}
.logo-v{font-size:.7rem;color:var(--dim);vertical-align:top;margin-left:2px;}

.vline{width:1px;height:20px;background:var(--brd);flex-shrink:0;}

/* Transport buttons */
.tbtn{
  display:inline-flex;align-items:center;justify-content:center;gap:4px;
  padding:5px 9px;border:1px solid var(--brd2);
  background:transparent;color:var(--dim);
  font-family:'Share Tech Mono',monospace;font-size:.7rem;
  letter-spacing:.08em;cursor:pointer;transition:all .12s;
  text-transform:uppercase;white-space:nowrap;flex-shrink:0;
}
.tbtn{font-size:.68rem!important;}
.tbtn:hover{border-color:var(--acc);color:var(--acc);}
.tbtn.active{border-color:var(--acc);color:var(--acc);box-shadow:0 0 10px rgba(0,255,170,.3);background:rgba(0,255,170,.06);}
.tbtn.drop-btn{border-color:var(--red);color:var(--red);}
.tbtn.drop-btn:hover,.tbtn.drop-btn.firing{box-shadow:0 0 14px rgba(255,34,68,.4);background:rgba(255,34,68,.08);}
.tbtn.rec-live{border-color:var(--red);color:var(--red);animation:recpulse .8s ease-in-out infinite alternate;}
@keyframes recpulse{from{box-shadow:0 0 6px rgba(255,34,68,.4)}to{box-shadow:0 0 18px rgba(255,34,68,.7)}}

.sring{width:7px;height:7px;border-radius:50%;border:2px solid var(--dim);transition:all .15s;flex-shrink:0;}
.sring.on{border-color:var(--acc);box-shadow:0 0 8px var(--acc);animation:sringpulse .45s ease-in-out infinite alternate;}
@keyframes sringpulse{from{opacity:1}to{opacity:.3}}

/* Groove buttons */
.groove-row{display:flex;gap:3px;flex-shrink:0;}
.gbtn{
  padding:4px 7px;border:1px solid var(--brd);
  background:transparent;color:var(--dim);
  font-family:'Share Tech Mono',monospace;font-size:.58rem;
  letter-spacing:.06em;cursor:pointer;transition:all .12s;text-transform:uppercase;
}
.gbtn:hover{border-color:var(--txt);color:var(--txt);}
.gbtn.active{border-color:var(--pur);color:var(--pur);background:rgba(170,68,255,.1);box-shadow:0 0 6px rgba(170,68,255,.25);}

/* BPM */
.bpm-wrap{display:flex;align-items:center;gap:3px;padding:3px 8px;border:1px solid var(--brd);background:rgba(0,0,0,.4);flex-shrink:0;}
.bpm-lbl{font-size:.55rem;color:var(--dim);letter-spacing:.15em;}
.bpm-num{font-family:'Bebas Neue',sans-serif;font-size:1.05rem;color:var(--acid);min-width:34px;text-align:center;}
.bpm-arrow{background:none;border:none;color:var(--dim);cursor:pointer;font-size:.8rem;padding:0 2px;transition:color .12s;}
.bpm-arrow:hover{color:var(--acc);}

/* Swing */
.sw-wrap{display:flex;align-items:center;gap:4px;padding:3px 7px;border:1px solid var(--brd);background:rgba(0,0,0,.4);flex-shrink:0;}
.sw-lbl{font-size:.55rem;color:var(--dim);letter-spacing:.12em;}
.sw-num{font-size:.7rem;color:var(--blu);min-width:28px;text-align:right;}
input[type=range]{-webkit-appearance:none;background:var(--brd);border-radius:2px;height:3px;outline:none;cursor:pointer;}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:10px;height:10px;border-radius:50%;background:var(--acc);box-shadow:0 0 4px var(--acc);}

/* REC button + indicator */
.rec-group{display:flex;align-items:center;gap:4px;flex-shrink:0;}
.rec-dot{width:8px;height:8px;border-radius:50%;background:var(--dim);flex-shrink:0;}
.rec-dot.live{background:var(--red);box-shadow:0 0 8px var(--red);animation:recpulse .5s infinite alternate;}

/* ═══ BODY LAYOUT ═════════════════════════════════════════ */
.body-wrap{
  display:flex;flex-direction:column;
  flex:1;min-height:0;overflow:hidden;
  min-height:0;
}
.panels-row{
  display:grid;grid-template-columns:100px repeat(4,1fr);
  gap:0;flex:1;min-height:0;overflow:hidden;
}
.panel-center{
  flex:1;min-width:0;
  display:grid;grid-template-columns:1fr 1fr;
  gap:0;overflow:hidden;
}

/* ── PANELS ── */
.panel{background:var(--panel);border:1px solid var(--brd);padding:6px 8px;display:flex;flex-direction:column;gap:5px;overflow-y:auto;overflow-x:hidden;}
.panel::-webkit-scrollbar{width:2px;}
.panel::-webkit-scrollbar-thumb{background:var(--brd2);border-radius:2px;}
.panel::-webkit-scrollbar{width:2px;}
.panel::-webkit-scrollbar-thumb{background:var(--brd2);}

.ptitle{font-family:'Bebas Neue',sans-serif;font-size:.6rem;letter-spacing:.18em;color:var(--dim);border-bottom:1px solid var(--brd);padding-bottom:2px;margin-bottom:2px;text-transform:uppercase;}

/* ── SOIL BUTTONS ── */
.soil-grid{display:grid;grid-template-columns:1fr 1fr;gap:3px;}
.soil-btn{padding:6px 4px;background:rgba(0,0,0,.5);border:1px solid var(--brd);color:var(--dim);font-family:'Share Tech Mono',monospace;font-size:.6rem;letter-spacing:.06em;cursor:pointer;transition:all .12s;text-align:center;text-transform:uppercase;}
.soil-btn:hover{border-color:var(--txt);color:var(--txt);}
.soil-btn[data-soil="dirt"].active{border-color:var(--acc);color:var(--acc);background:rgba(0,255,170,.07);}
.soil-btn[data-soil="metal"].active{border-color:var(--blu);color:var(--blu);background:rgba(68,170,255,.07);}
.soil-btn[data-soil="flesh"].active{border-color:var(--top);color:var(--top);background:rgba(255,68,136,.07);}
.soil-btn[data-soil="void"].active{border-color:var(--pur);color:var(--pur);background:rgba(170,68,255,.07);}

/* ── KNOBS ── */
.knob-grid{display:grid;grid-template-columns:1fr 1fr;gap:4px;}
.knob-wrap{display:flex;flex-direction:column;align-items:center;gap:3px;cursor:ns-resize;touch-action:none;}
.knob-canvas{display:block;}
.kname{font-size:.5rem;letter-spacing:.1em;color:var(--dim);text-transform:uppercase;text-align:center;}
.kval{font-size:.58rem;color:var(--acc);text-align:center;}

/* ── LAYER MIX ── */
.layer-row{display:flex;flex-direction:column;gap:5px;}
.layer-item{display:flex;align-items:center;gap:4px;}
.lname{font-size:.55rem;letter-spacing:.08em;min-width:32px;text-transform:uppercase;}
.lbar{flex:1;height:4px;background:var(--brd);border-radius:2px;cursor:ew-resize;position:relative;overflow:hidden;}
.lfill{height:100%;border-radius:2px;transition:width .06s;}
.lval{font-size:.55rem;min-width:22px;text-align:right;}

/* ── MOD MATRIX ── */
.mod-matrix{display:flex;flex-direction:column;gap:3px;}
.mod-row{display:flex;align-items:center;gap:5px;}
.msrc{font-size:.55rem;color:var(--pur);min-width:36px;}
.marr{font-size:.55rem;color:var(--dim);}
.mtgt{font-size:.55rem;color:var(--mid);min-width:48px;}
.mbar{flex:1;height:3px;background:var(--brd);border-radius:2px;cursor:ew-resize;overflow:hidden;}
.mfill{height:100%;border-radius:2px;}

/* ── METERS ── */
.meter-row{display:flex;align-items:center;gap:3px;}
.mlbl{font-size:.52rem;color:var(--dim);min-width:28px;letter-spacing:.06em;}
.mtrack{flex:1;height:4px;background:var(--brd);border-radius:2px;overflow:hidden;}
.mfill2{height:100%;border-radius:2px;transition:width .04s;}

/* ═══ VISUALISER ══════════════════════════════════════════ */
.viz-wrap{
  position:relative;background:#010204;
  border-right:1px solid var(--brd);
  overflow:hidden;
  /* slim left column inside panels-row */
}
#vizCanvas{display:block;width:100%;height:100%;}
.viz-hud{position:absolute;inset:0;pointer-events:none;display:flex;flex-direction:column;justify-content:space-between;padding:8px 12px;}
.vhud-row{display:flex;justify-content:space-between;}
.vhud-tl{font-size:.58rem;color:rgba(0,255,170,.4);letter-spacing:.16em;font-family:'Bebas Neue',sans-serif;}
.vhud-tr{font-size:.58rem;color:rgba(200,255,0,.4);letter-spacing:.1em;text-align:right;}
.vhud-bl{font-size:.52rem;color:rgba(0,200,255,.3);letter-spacing:.1em;}
.vhud-br{font-size:.52rem;color:rgba(255,60,60,.5);text-align:right;letter-spacing:.08em;}

/* ═══ SEQUENCER ══════════════════════════════════════════ */
.seq-wrap{background:var(--panel);border-top:1px solid var(--brd);padding:5px 10px 7px;flex-shrink:0;}
.seq-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;gap:6px;flex-wrap:nowrap;}
.seq-title{font-family:'Bebas Neue',sans-serif;font-size:.62rem;letter-spacing:.18em;color:var(--dim);white-space:nowrap;flex-shrink:0;}
.seq-legend{display:flex;gap:10px;font-size:.55rem;color:var(--dim);flex-shrink:0;}
.seq-legend span{display:flex;align-items:center;gap:3px;}
.leg-main{font-size:.62rem;color:var(--txt);letter-spacing:.06em;}
.leg-sub{font-size:.52rem;color:var(--dim);letter-spacing:.04em;}
.ldot{width:6px;height:6px;border-radius:2px;}

.steps-grid{display:grid;grid-template-columns:repeat(16,1fr);gap:2px;}
.step-col{display:flex;flex-direction:column;align-items:center;gap:1px;}
.snum{font-size:.42rem;color:var(--brd2);height:8px;line-height:8px;}

.pad{
  width:100%;aspect-ratio:1/.85;background:rgba(0,0,0,.7);
  border:1px solid var(--brd);border-radius:2px;
  cursor:pointer;position:relative;overflow:hidden;
  transition:border-color .08s,transform .06s;
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1px;
}
.pad.on{background:rgba(0,255,170,.08);border-color:var(--acc);}
.pad.ac{background:rgba(255,34,68,.08);border-color:var(--red);}
.pad.sl{background:rgba(255,136,0,.08);border-color:var(--ora);}
.pad.now{box-shadow:0 0 10px rgba(0,255,170,.7),inset 0 0 6px rgba(0,255,170,.15)!important;transform:scaleY(.92)!important;}
.padbar{width:55%;height:3px;border-radius:2px;background:var(--dim);}
.pad.on .padbar{background:var(--acc);}
.pad.ac .padbar{background:var(--red);}
.pad.sl .padbar{background:var(--ora);}
.padnote{font-size:.45rem;color:var(--dim);line-height:1;}
.pad.on .padnote{color:var(--acc);}
.pad.ac .padnote{color:var(--red);}
.pad.sl .padnote{color:var(--ora);}
.padflags{display:flex;gap:1px;}
.flag{width:8px;height:8px;border:1px solid;display:flex;align-items:center;justify-content:center;font-size:.38rem;cursor:pointer;border-radius:1px;transition:all .08s;}
.flag-a{border-color:rgba(255,34,68,.3);color:rgba(255,34,68,.4);}
.flag-s{border-color:rgba(255,136,0,.3);color:rgba(255,136,0,.4);}
.flag-a.on{background:var(--red);border-color:var(--red);color:#000;}
.flag-s.on{background:var(--ora);border-color:var(--ora);color:#000;}

/* ═══ EXPORT BAR ════════════════════════════════════════ */
.xbar{
  display:flex;align-items:center;gap:6px;
  padding:6px 14px;background:rgba(0,0,0,.6);
  border-top:1px solid var(--brd);flex-shrink:0;flex-wrap:nowrap;overflow:hidden;
}
.xbtn{
  padding:4px 10px;background:transparent;border:1px solid var(--brd);
  color:var(--dim);font-family:'Share Tech Mono',monospace;font-size:.62rem;
  letter-spacing:.08em;cursor:pointer;transition:all .12s;text-transform:uppercase;
  white-space:nowrap;flex-shrink:0;
}
.xbtn:hover{border-color:var(--ora);color:var(--ora);}
.seed-area{margin-left:auto;font-size:.58rem;color:var(--dim);letter-spacing:.08em;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.seedv{color:var(--acid);cursor:pointer;}

/* ═══ REC DRAWER (slide-out from bottom) ═══════════════ */
#recDrawer{
  position:fixed;bottom:0;left:0;right:0;z-index:1000;
  transform:translateY(100%);
  transition:transform .32s cubic-bezier(.22,.9,.3,1);
  pointer-events:none;
}
#recDrawer.open{transform:translateY(0);pointer-events:all;}
#recDrawer-backdrop{
  position:fixed;inset:0;z-index:999;
  background:rgba(0,0,0,.55);backdrop-filter:blur(3px);
  opacity:0;pointer-events:none;
  transition:opacity .28s;
}
#recDrawer-backdrop.open{opacity:1;pointer-events:all;}
.rec-drawer-inner{
  background:var(--panel);
  border-top:2px solid var(--red);
  border-left:1px solid var(--brd2);border-right:1px solid var(--brd2);
  padding:0;
  box-shadow:0 -8px 40px rgba(0,0,0,.8),0 -2px 20px rgba(255,34,68,.15);
  max-width:900px;margin:0 auto;position:relative;
}
/* Handle bar to grab / show it exists */
.rec-handle{
  display:flex;align-items:center;justify-content:space-between;
  padding:10px 20px 8px;
  border-bottom:1px solid var(--brd);cursor:pointer;
}
.rec-handle-title{
  font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:.22em;
  color:var(--red);text-shadow:0 0 10px rgba(255,34,68,.4);
  display:flex;align-items:center;gap:10px;
}
.rec-handle-dot{width:8px;height:8px;border-radius:50%;background:var(--dim);flex-shrink:0;}
.rec-handle-dot.live{background:var(--red);box-shadow:0 0 8px var(--red);animation:recpulse .5s infinite alternate;}
.rec-handle-close{background:none;border:none;color:var(--dim);cursor:pointer;font-size:.9rem;letter-spacing:.1em;font-family:'Share Tech Mono',monospace;transition:color .12s;}
.rec-handle-close:hover{color:var(--txt);}
.rec-body{
  display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));
  gap:0;padding:14px 20px 16px;
}
.rec-col{display:flex;flex-direction:column;gap:8px;padding:0 12px;border-right:1px solid var(--brd);}
.rec-col:first-child{padding-left:0;}
.rec-col:last-child{border-right:none;padding-right:0;}
.rec-field{display:flex;flex-direction:column;gap:5px;}
.rec-lbl{font-size:.58rem;color:var(--dim);letter-spacing:.14em;text-transform:uppercase;}
.rec-opts{display:flex;gap:4px;flex-wrap:wrap;}
.rec-opt{
  padding:4px 10px;border:1px solid var(--brd);
  background:transparent;color:var(--dim);
  font-family:'Share Tech Mono',monospace;font-size:.6rem;
  cursor:pointer;transition:all .1s;text-transform:uppercase;letter-spacing:.06em;
}
.rec-opt:hover{border-color:var(--txt);color:var(--txt);}
.rec-opt.selected{border-color:var(--red);color:var(--red);background:rgba(255,34,68,.08);}
.rec-start-btn{
  width:100%;padding:10px 6px;margin-top:4px;
  background:rgba(255,34,68,.1);border:1px solid var(--red);
  color:var(--red);font-family:'Bebas Neue',sans-serif;font-size:.95rem;
  letter-spacing:.18em;cursor:pointer;transition:all .14s;white-space:nowrap;
}
.rec-start-btn:hover{background:rgba(255,34,68,.2);box-shadow:0 0 16px rgba(255,34,68,.3);}
.rec-start-btn.recording{border-color:var(--acc);color:var(--acc);background:rgba(0,255,170,.07);}
.rec-status{font-size:.58rem;color:var(--dim);text-align:center;letter-spacing:.1em;min-height:16px;margin-top:4px;}
.rec-progress{height:2px;background:var(--brd);overflow:hidden;margin-top:4px;}
.rec-prog-fill{height:100%;background:var(--red);width:0%;transition:width .5s linear;box-shadow:0 0 5px var(--red);}

/* ── Minimised recording tab ── */
#recMinTab{
  position:fixed;bottom:0;left:50%;transform:translateX(-50%);z-index:1001;
  display:none;
  padding:5px 22px 4px;
  background:var(--panel);border:1px solid var(--red);border-bottom:none;
  font-family:'Bebas Neue',sans-serif;font-size:.75rem;letter-spacing:.18em;
  color:var(--red);cursor:pointer;transition:all .15s;
}
#recMinTab.visible{display:flex;align-items:center;gap:8px;}
#recMinTab:hover{background:rgba(255,34,68,.1);}
.rec-min-dot{width:6px;height:6px;border-radius:50%;background:var(--red);box-shadow:0 0 6px var(--red);animation:recpulse .5s infinite alternate;}

/* ── HELP MODAL ── */
#helpModal{
  display:none;position:fixed;inset:0;z-index:2000;
  background:rgba(0,0,0,.85);backdrop-filter:blur(6px);
  align-items:flex-start;justify-content:center;
  padding:40px 20px;overflow-y:auto;
}
#helpModal.open{display:flex;}
.help-panel{
  background:var(--panel);border:1px solid var(--acid);
  padding:0;max-width:700px;width:100%;position:relative;
  box-shadow:0 0 60px rgba(0,0,0,.9),0 0 30px rgba(200,255,0,.08);
}
.help-hdr{
  display:flex;align-items:center;justify-content:space-between;
  padding:14px 20px;border-bottom:1px solid var(--brd);
  background:rgba(200,255,0,.04);
}
.help-title{
  font-family:'Bebas Neue',sans-serif;font-size:1.3rem;letter-spacing:.22em;
  color:var(--acid);text-shadow:0 0 12px rgba(200,255,0,.4);
}
.help-close{background:none;border:none;color:var(--dim);cursor:pointer;font-size:.8rem;letter-spacing:.1em;font-family:'Share Tech Mono',monospace;transition:color .12s;}
.help-close:hover{color:var(--txt);}
.help-body{padding:20px;display:flex;flex-direction:column;gap:18px;}
.help-section{display:flex;flex-direction:column;gap:6px;}
.help-sh{
  font-family:'Bebas Neue',sans-serif;font-size:.85rem;letter-spacing:.2em;
  color:var(--acc);border-bottom:1px solid var(--brd);padding-bottom:4px;margin-bottom:2px;
}
.help-grid{display:grid;grid-template-columns:1fr 1fr;gap:4px 16px;}
.help-row{display:flex;gap:8px;align-items:baseline;padding:2px 0;}
.help-key{
  font-family:'Bebas Neue',sans-serif;font-size:.72rem;letter-spacing:.1em;
  color:var(--acid);min-width:90px;flex-shrink:0;
}
.help-desc{font-size:.6rem;color:var(--txt);letter-spacing:.04em;line-height:1.5;}
.help-tip{
  font-size:.6rem;color:var(--dim);
  border-left:2px solid var(--acc);padding-left:10px;margin-top:4px;
  line-height:1.6;letter-spacing:.04em;
}

/* select */
select{background:rgba(0,0,0,.6);border:1px solid var(--brd);color:var(--txt);font-family:'Share Tech Mono',monospace;font-size:.68rem;padding:4px 6px;width:100%;cursor:pointer;outline:none;}
select:focus{border-color:var(--acc);}

/* rbtn */
.rbtn{padding:8px;background:transparent;border:1px solid var(--brd);color:var(--dim);font-family:'Share Tech Mono',monospace;font-size:.7rem;letter-spacing:.1em;cursor:pointer;transition:all .15s;text-transform:uppercase;text-align:center;}
.rbtn:hover{border-color:var(--acid);color:var(--acid);}

/* rng row */
.rng-row{display:flex;flex-direction:column;gap:3px;}
.rng-lbl{display:flex;justify-content:space-between;font-size:.55rem;color:var(--dim);letter-spacing:.08em;text-transform:uppercase;}
.rng-lbl span{color:var(--acc);}

/* Screen shake */
@keyframes shake{0%,100%{transform:translate(0,0)}15%{transform:translate(-3px,2px)}30%{transform:translate(3px,-2px)}45%{transform:translate(-4px,1px)}60%{transform:translate(4px,-1px)}75%{transform:translate(-2px,2px)}90%{transform:translate(2px,-2px)}}
.shake{animation:shake .3s ease-out;}

/* == TOOLTIP == */
.wb-tip{position:fixed;z-index:9999;pointer-events:none;opacity:0;
  background:rgba(4,7,12,.97);border:1px solid var(--acc);color:var(--txt);
  font-family:'Share Tech Mono',monospace;font-size:.56rem;letter-spacing:.06em;
  line-height:1.55;padding:6px 10px;max-width:200px;text-align:center;
  box-shadow:0 0 14px rgba(0,255,170,.14);transition:opacity .15s;white-space:normal;}
.wb-tip.on{opacity:1;}
.wb-tip::after{content:'';position:absolute;left:50%;transform:translateX(-50%);
  border:5px solid transparent;}
.wb-tip.tip-below::after{bottom:100%;border-bottom-color:var(--acc);border-top-color:transparent;}
.wb-tip.tip-above::after{top:100%;border-top-color:var(--acc);border-bottom-color:transparent;}
/* == SECTION HEADERS == */
.sec-hdr{display:flex;align-items:center;justify-content:space-between;
  border-bottom:1px solid var(--brd);padding-bottom:2px;margin-bottom:2px;}
.sec-lbl{font-family:'Bebas Neue',sans-serif;font-size:.65rem;
  letter-spacing:.2em;color:var(--dim);text-transform:uppercase;}
.sec-acts{display:flex;gap:3px;}
.smbtn{padding:2px 7px;background:transparent;border:1px solid var(--brd);
  color:var(--dim);font-family:'Share Tech Mono',monospace;font-size:.5rem;
  letter-spacing:.06em;cursor:pointer;transition:all .1s;text-transform:uppercase;}
.smbtn:hover{border-color:var(--acc);color:var(--acc);}
.smbtn.rst:hover{border-color:var(--red);color:var(--red);}
/* == THEME PANEL == */
#themePanel{position:fixed;top:52px;right:0;z-index:600;
  background:var(--panel);border:1px solid var(--brd2);border-top:none;
  padding:12px 14px;min-width:200px;box-shadow:-3px 0 20px rgba(0,0,0,.7);
  transform:translateX(102%);transition:transform .28s cubic-bezier(.22,.9,.3,1);}
#themePanel.open{transform:translateX(0);}
.th-ttl{font-family:'Bebas Neue',sans-serif;font-size:.7rem;letter-spacing:.2em;
  color:var(--dim);margin-bottom:8px;}
.th-grid{display:flex;flex-direction:column;gap:4px;}
.th-opt{display:flex;align-items:center;gap:8px;padding:6px 8px;
  border:1px solid var(--brd);background:transparent;cursor:pointer;
  font-family:'Share Tech Mono',monospace;font-size:.6rem;color:var(--dim);
  letter-spacing:.07em;width:100%;transition:all .1s;}
.th-opt:hover{border-color:var(--txt);color:var(--txt);}
.th-opt.active{border-color:var(--acc);color:var(--acc);}
.th-sw{display:flex;gap:3px;flex-shrink:0;}
.th-s{width:9px;height:9px;border-radius:2px;}
/* == MOBILE == */
/* ═══ MOBILE ════════════════════════════════════════════ */
@media(max-width:700px){
  /* Root: allow full scroll on mobile */
  html,body{overflow:auto;height:auto;}
  #app{height:auto;overflow:visible;}

  /* Header: wrap onto two rows, all items visible */
  .hdr{position:sticky;top:0;z-index:200;}
  .hdr-row1{flex-wrap:wrap;gap:4px;padding:4px 8px;min-height:auto;overflow:visible;}
  .hdr-row2{flex-wrap:wrap;gap:6px;padding:4px 8px;min-height:auto;}
  .logo{font-size:1.2rem;}
  .tbtn{padding:5px 7px;font-size:.6rem!important;}
  .gbtn{font-size:.6rem;padding:4px 6px;}
  .bpm-wrap,.sw-wrap{font-size:.6rem;}
  .bpm-num{font-size:.95rem;min-width:28px;}
  #swingSlider{width:55px!important;}
  .vline{display:none;}
  .sring{display:none;}

  /* Body: stack vertically, full width */
  .body-wrap{
    display:flex!important;flex-direction:column!important;
    overflow:visible;height:auto;flex:none;
  }
  .panels-row{
    display:flex!important;flex-direction:column!important;
    overflow:visible;height:auto;flex:none;gap:0;
  }

  /* Viz: full width strip, fixed height */
  .viz-wrap{
    width:100%;height:120px;border-right:none;
    border-bottom:1px solid var(--brd);flex-shrink:0;
  }
  #circCanvas{max-height:none;}

  /* Panels: all visible, stacked, full width */
  .panel{
    display:flex!important;
    width:100%;min-height:auto;
    overflow:visible;border-left:none;border-right:none;
    padding:10px 12px;
  }

  /* Knobs: slightly bigger for touch */
  .knob-wrap canvas{width:48px!important;height:48px!important;}

  /* Soil + action buttons: 2-per-row grid */
  .soil-grid{grid-template-columns:1fr 1fr;gap:6px;}
  .soil-btn{padding:10px 4px;font-size:.7rem;}

  /* Knob grids: 4-per-row on mobile */
  .knob-grid{grid-template-columns:repeat(4,1fr);gap:6px;}

  /* Sequencer: horizontal scroll */
  .seq-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch;padding:8px;}
  .steps-grid{
    display:flex!important;flex-direction:row!important;
    min-width:640px;gap:3px;
    grid-template-columns:none!important;
  }
  .step-col{flex:0 0 calc(640px/16 - 3px);}

  /* Export bar: wraps */
  .xbar{flex-wrap:wrap;gap:5px;padding:8px;}
  .xbtn{font-size:.65rem;padding:6px 8px;}

  /* Section headers */
  .sec-hdr{margin-top:8px!important;}
  .sec-lbl{font-size:.68rem;}

  /* Layer mix */
  .layer-row{flex-wrap:wrap;}

  /* Mod matrix */
  .mod-matrix{flex-direction:column;}

  /* Meters: smaller */
  .meter-row{gap:4px;}
  .meter-bar-bg{width:60px!important;}

  /* Seq legend wraps */
  .seq-legend{flex-wrap:wrap;gap:6px;}
  .seq-top{flex-wrap:wrap;gap:4px;}

  /* Dist type select full width */
  #distType{width:100%!important;}

  /* Circ viz col in panels: show as strip */
  .circ-wrap{max-height:120px;}
}

/* Slightly larger mobile (tablet portrait) */
@media(min-width:701px) and (max-width:900px){
  .panels-row{grid-template-columns:100px 1fr 1fr!important;}
  .panels-row .panel:nth-child(4),
  .panels-row .panel:nth-child(5){
    grid-column:2/4;
  }
}

/* Wriggle button: text appears on hover */
#wriggle-label{
  opacity:0;
  transition:opacity .4s ease;
  pointer-events:none;
}
#wriggle-btn:hover #wriggle-label{opacity:1;}

/* Bounce arrow above wriggle button */
#wriggle-arrow{
  font-size:2rem;
  color:rgba(200,255,0,.7);
  text-shadow:0 0 16px rgba(200,255,0,.6);
  animation:arrowbounce 1.1s ease-in-out infinite;
  display:block;
  line-height:1;
  margin-bottom:8px;
  user-select:none;
  pointer-events:none;
}
@keyframes arrowbounce{
  0%,100%{transform:translateY(0);}
  50%{transform:translateY(10px);}
}

/* ── Circular viz ── */
#circCanvas{display:block;width:100%;height:100%;}
.circ-wrap{
  width:100%;flex:1;min-height:0;
  overflow:hidden;
  display:flex;align-items:center;justify-content:center;
  padding:4px;
}
</style>
</head>
<body>

<!-- ═══════════════ SPLASH SCREEN ═══════════════ -->
<div id="splash">
  <img id="splash-img" src="data:image/jpeg;base64," alt="WORMBASS">
  <div id="splash-overlay"></div>
  <div id="splash-vignette"></div>
  <div id="splash-scanlines"></div>
  <div id="splash-flicker"></div>
  <div class="splash-content">
    <div class="splash-tagline">Self-Digging Acid Bass Engine</div>
    <div id="splash-loader"><div id="splash-loader-fill"></div></div>
    <span id="wriggle-arrow">▼</span>
    <button id="wriggle-btn" onclick="startApp()">
      <div class="wriggle-worms">
        <div class="splash-worm" style="left:8%;animation-delay:0s;animation-duration:2.2s"></div>
        <div class="splash-worm" style="left:22%;animation-delay:.4s;animation-duration:2.8s"></div>
