// ── SEED / EXPORT ─────────────────────────────────────
function getPatchData(){
  return {
    // Transport
    soil, groove, bpm, swing,
    // Dist type selector
    distType: (document.getElementById('distType')||{value:'reese'}).value,
    // All synth params (P contains: detune, waveshape, depth, chaos,
    //   attack, decay, sustain, release, cutoff, res, envMod, filterDrive,
    //   drive, fold, clip, density, lfo1Rate, lfo1Depth, lfo2Rate, lfo2Depth,
    //   mod_lfo1_cutoff, mod_lfo2_pitch, mod_env_dist, mod_chaos_width, mod_lfo1_delay,
    //   bpFreq, bpQ)
    p: Object.fromEntries(Object.entries(P).map(([k,v])=>[k, typeof v==='number'?Math.round(v*100)/100:v])),
    // Layer mix
    l: {sub:Math.round(layerGains.sub*100), mid:Math.round(layerGains.mid*100), top:Math.round(layerGains.top*100)},
    // Full 16-step sequencer: on/accent/slide/note/velocity per step
    s: steps.map(s=>({o:s.on?1:0, a:s.ac?1:0, sl:s.sl?1:0, n:s.note, v:s.vel})),
    // Metadata
    version:6, savedAt:Date.now()
  };
}
function getSeed(){
  return btoa(JSON.stringify(getPatchData())).replace(/=/g,'').slice(0,16).toUpperCase();
}
function updateSeed(){const el=document.getElementById('seedDisp');if(el)el.textContent=getSeed();}

function applyPatch(d){
  if(!d)return;
  // 1. Set soil/groove with skipRandomize=true so they don't wipe the pattern
  if(d.soil) soilCtrl.set(d.soil, document.querySelector('[data-soil="'+d.soil+'"]'), true);
  if(d.groove) grooveCtrl.set(d.groove, document.querySelector('[data-groove="'+d.groove+'"]'), true);
  // 2. BPM — override what grooveCtrl set (patch BPM takes priority)
  if(d.bpm){bpm=d.bpm; document.getElementById('bpmNum').textContent=bpm;}
  // 3. Swing — override what grooveCtrl set
  if(typeof d.swing!=='undefined'){
    swing=d.swing;
    document.getElementById('swingSlider').value=d.swing;
    document.getElementById('swingNum').textContent=d.swing+'%';
  }
  // 4. All synth params
  if(d.p) Object.assign(P,d.p);
  // 5. Layer mix
  if(d.l){layerGains.sub=d.l.sub/100;layerGains.mid=d.l.mid/100;layerGains.top=d.l.top/100;}
  // 6. Dist type
  if(d.distType){
    const sel=document.getElementById('distType');
    if(sel){sel.value=d.distType; synth.setDistType(d.distType);}
  }
  // 7. Mod matrix amounts (stored in P already, but also update bars)
  ['mod_lfo1_cutoff','mod_lfo2_pitch','mod_env_dist','mod_chaos_width','mod_lfo1_delay'].forEach(k=>{
    const el=document.getElementById('mf_'+k);
    if(el&&P[k]!==undefined) el.style.width=P[k]+'%';
  });
  // 8. Sequencer steps — LAST, after soil/groove so nothing overwrites them
  if(d.s) d.s.forEach((s,i)=>{
    if(i>=steps.length)return;
    steps[i].on=!!s.o;
    steps[i].ac=!!s.a;
    steps[i].sl=!!s.sl;
    steps[i].note=s.n||'A1';
    steps[i].vel=typeof s.v==='number'?s.v:80;
  });
  // 9. Refresh all UI
  renderPads();
  allKnobs.forEach(k=>{
    const el=document.getElementById('kv_'+k.key);
    if(el) el.textContent=Math.round(P[k.key]);
    k.draw();
  });
  ['sub','mid','top'].forEach(layer=>{
    const fill=document.getElementById('lf_'+layer), val=document.getElementById('lv_'+layer);
    if(fill) fill.style.width=(layerGains[layer]*100)+'%';
    if(val)  val.textContent=Math.round(layerGains[layer]*100);
    synth.setLayer(layer,layerGains[layer]*100);
  });
  buildDistCurves();
  // 10. Sync live audio nodes if running
  if(lpFilter){
    lpFilter.frequency.value=mapCutoff(P.cutoff);
    lpFilter.Q.value=mapRes(P.res);
  }
  if(lfo1Osc) lfo1Osc.frequency.value=mapLfoRate(P.lfo1Rate);
  if(lfo1Gain) lfo1Gain.gain.value=mapLfoDepth(P.lfo1Depth)*(P.mod_lfo1_cutoff/100);
  if(playing){clearInterval(ticker);ticker=setInterval(seq.tick,stepLen()*1000);}
  updateSeed();
}

const exportFns=(()=>{
