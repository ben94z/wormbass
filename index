  attack:4,decay:55,sustain:60,release:30,
  cutoff:42,res:38,envMod:62,filterDrive:22,
  drive:28,fold:8,clip:6,density:52,
  lfo1Rate:14,lfo1Depth:22,lfo2Rate:48,lfo2Depth:8,
};
const SEC_RANGES={
  detune:[0,50],waveshape:[0,100],depth:[0,100],chaos:[0,100],
  attack:[1,200],decay:[5,600],sustain:[0,100],release:[5,400],
  cutoff:[0,100],res:[0,100],envMod:[0,100],filterDrive:[0,100],
  drive:[0,100],fold:[0,100],clip:[0,100],density:[10,100],
  lfo1Rate:[1,100],lfo1Depth:[0,100],lfo2Rate:[1,100],lfo2Depth:[0,100],
