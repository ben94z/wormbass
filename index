// ── TOOLTIP ENGINE ────────────────────────────────────
(()=>{
  let tip=null,timer=null,active=null;
  function mk(){
    tip=document.createElement('div');
    tip.className='wb-tip';
    document.body.appendChild(tip);
  }
  function show(el,txt){
    if(!tip)mk();
    tip.textContent=txt;
    const r=el.getBoundingClientRect();
    const spaceAbove=r.top;
    const spaceBelow=window.innerHeight-r.bottom;
    if(spaceBelow>80||spaceBelow>spaceAbove){
      // Show below
      tip.classList.remove('tip-above');tip.classList.add('tip-below');
      tip.style.left=(r.left+r.width/2)+'px';
      tip.style.top=(r.bottom+8)+'px';
      tip.style.transform='translateX(-50%)';
    } else {
      // Show above
      tip.classList.remove('tip-below');tip.classList.add('tip-above');
      tip.style.left=(r.left+r.width/2)+'px';
      tip.style.top=(r.top-8)+'px';
      tip.style.transform='translate(-50%,-100%)';
    }
    tip.classList.add('on');
  }
  function hide(){if(tip)tip.classList.remove('on');}
  document.addEventListener('mouseover',e=>{
    const el=e.target.closest('[data-tip]');
    clearTimeout(timer); hide(); active=null;
    if(el&&el.dataset.tip){
      active=el;
      timer=setTimeout(()=>{if(active===el)show(el,el.dataset.tip);},3000);
    }
  });
  document.addEventListener('mouseout',e=>{
    if(e.target.closest('[data-tip]')){clearTimeout(timer);hide();active=null;}
  });
  // Touch long-press
  let tt=null,te=null;
  document.addEventListener('touchstart',e=>{
    const el=e.target.closest('[data-tip]');
    clearTimeout(tt); hide();
    if(el&&el.dataset.tip){te=el; tt=setTimeout(()=>{if(te===el)show(el,el.dataset.tip);},1200);}
  },{passive:true});
  document.addEventListener('touchend',()=>{clearTimeout(tt);setTimeout(hide,1600);},{passive:true});
})();

