const ui=(()=>{
  function _refresh(keys){
    allKnobs.forEach(k=>{
      if(!keys.includes(k.key))return;
      const el=document.getElementById('kv_'+k.key);
      if(el)el.textContent=Math.round(P[k.key]);
      k.draw();
    });
    buildDistCurves();
  }
  function rnd(sec){
    (SEC_KEYS[sec]||[]).forEach(k=>{
      const [mn,mx]=SEC_RANGES[k]||[0,100];
      P[k]=mn+Math.random()*(mx-mn);
      synth.set(k,P[k]);
