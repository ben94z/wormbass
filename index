// ── CIRCULAR WIRE VISUALIZER ─────────────────────────
const CIRC=(()=>{
  const cv=document.getElementById('circCanvas');
  if(!cv)return{};
  const cx=cv.getContext('2d',{alpha:true});
  let W=0,H=0,R=0,cx2=0,cy2=0;
  // Pre-allocated typed array for FFT points
  let fBuf=null;
  let frameN=0;
  // Smoothed colour R,G,B from worm (lime green default)
  let wR=0,wG=255,wB=136;

  function resize(){
    const ow=cv.offsetWidth, oh=cv.offsetHeight;
    if(!ow||!oh)return;
    // Use the actual element dimensions — square based on smallest side
    const sz=Math.min(ow,oh);
    cv.width=sz; cv.height=sz;
    W=sz; H=sz; cx2=sz/2; cy2=sz/2;
    // R is the base ring radius — leave 16px padding on each side for glow/spikes
    R=(sz/2)-16;
    if(R<4) R=4;
  }

  function setSoil(s){
    // sync colour with main worm
    const cfg=(typeof SOIL_CFG!=='undefined'&&SOIL_CFG[s])||{color:'#00ff88'};
    const x=(cfg.color||'#00ff88').replace('#','');
    wR=parseInt(x.slice(0,2),16);
    wG=parseInt(x.slice(2,4),16);
    wB=parseInt(x.slice(4,6),16);
  }

  function frame(){
    if(!W){resize();}
    frameN++;

    // Clear (transparent bg — shows panel behind)
    cx.clearRect(0,0,W,H);

    if(!playing){
      // Draw faint static circle when stopped
      cx.strokeStyle=`rgba(${wR},${wG},${wB},0.12)`;
      cx.lineWidth=1;cx.beginPath();
      cx.arc(cx2,cy2,R,0,6.283);cx.stroke();
      requestAnimationFrame(frame);return;
    }

    if(!analyser){requestAnimationFrame(frame);return;}

    const n=analyser.frequencyBinCount;
    if(!fBuf||fBuf.length!==n) fBuf=new Uint8Array(n);
    analyser.getByteFrequencyData(fBuf);

    // Use first 64 bins mapped around circle
    const BINS=64;
    const step=Math.max(1,(n/BINS)|0);
    const sliceAngle=(Math.PI*2)/BINS;

    // Hard clip radius — spikes must stay inside canvas (R + padding = half canvas)
    const maxR=W/2-2;

    // Set clip region = full circle — nothing draws outside
    cx.save();
    cx.beginPath();
    cx.arc(cx2,cy2,maxR,0,6.283);
    cx.clip();

    // ── Outer reactive ring ──
    // CRITICAL: offset start angle by half a slice so NO data point
    // lands at 12-o-clock (top). The join always falls between two bins
    // where adjacent values are close — invisible seam, no peak ever.
    const angleOffset = -Math.PI/2 + sliceAngle*0.5;
    const outerPts=new Float32Array(BINS*2);
    for(let i=0;i<BINS;i++){
      const val=fBuf[i*step]/255;
      const ang=angleOffset+i*sliceAngle;
      // Smooth the radius a little: average with neighbours for gentler bumps
      const valPrev=fBuf[((i-1+BINS)%BINS)*step]/255;
      const valNext=fBuf[((i+1)%BINS)*step]/255;
      const smoothVal=(valPrev+val*2+valNext)/4;
      const outerR=Math.min(maxR, R+smoothVal*(maxR-R)*0.75);
      outerPts[i*2]  =cx2+Math.cos(ang)*outerR;
      outerPts[i*2+1]=cy2+Math.sin(ang)*outerR;
    }
    // Start at midpoint between last and first — seamless wrap
    const lastI=(BINS-1)*2;
    const startX=(outerPts[lastI]+outerPts[0])/2;
    const startY=(outerPts[lastI+1]+outerPts[1])/2;
    cx.beginPath();
    cx.moveTo(startX,startY);
    for(let i=0;i<BINS;i++){
      const ci=i*2, ni=((i+1)%BINS)*2;
      cx.quadraticCurveTo(
        outerPts[ci],outerPts[ci+1],
        (outerPts[ci]+outerPts[ni])/2,
        (outerPts[ci+1]+outerPts[ni+1])/2
      );
    }
    cx.closePath();
    cx.shadowColor=`rgb(${wR},${wG},${wB})`;
    cx.shadowBlur=5;
    cx.strokeStyle=`rgba(${wR},${wG},${wB},0.6)`;
    cx.lineWidth=1.4; cx.stroke();
    cx.shadowBlur=0;

    // ── Inner smooth waveform circle — seamless ──
    analyser.getByteTimeDomainData(fBuf);
    const wavePts=new Float32Array(BINS*2);
    for(let i=0;i<BINS;i++){
      const val=(fBuf[i*step]-128)/128;
      const ang=angleOffset+i*sliceAngle;  // same offset — no point at 12-o-clock
      const r2=R*(0.52+val*0.18);
      wavePts[i*2]  =cx2+Math.cos(ang)*r2;
      wavePts[i*2+1]=cy2+Math.sin(ang)*r2;
    }
    const wLastI=(BINS-1)*2;
    const wStartX=(wavePts[wLastI]+wavePts[0])/2;
    const wStartY=(wavePts[wLastI+1]+wavePts[1])/2;
    cx.beginPath();
    cx.moveTo(wStartX,wStartY);
    for(let i=0;i<BINS;i++){
      const ci=i*2, ni=((i+1)%BINS)*2;
      const midX=(wavePts[ci]+wavePts[ni])/2;
      const midY=(wavePts[ci+1]+wavePts[ni+1])/2;
      cx.quadraticCurveTo(wavePts[ci],wavePts[ci+1],midX,midY);
    }
    cx.closePath();
    cx.strokeStyle=`rgba(${wR},${wG},${wB},0.88)`;
    cx.lineWidth=1.5;
    cx.shadowColor=`rgb(${wR},${wG},${wB})`;
    cx.shadowBlur=5;
    cx.stroke();
    cx.shadowBlur=0;

    // ── Centre dot — pulsates with sub bass ──
    // Read sub bass from FFT
    let sub=0;
    for(let i=0;i<4;i++) sub+=fBuf[i*step];
    sub=sub/(4*255);
    const dotR=R*(0.06+sub*0.18);
    const dg=cx.createRadialGradient(cx2,cy2,0,cx2,cy2,Math.max(0.1,dotR*2));
    dg.addColorStop(0,`rgba(255,255,255,0.9)`);
    dg.addColorStop(0.3,`rgba(${wR},${wG},${wB},0.9)`);
    dg.addColorStop(1,`rgba(${wR},${wG},${wB},0)`);
    cx.fillStyle=dg;
    cx.shadowColor=`rgb(${wR},${wG},${wB})`;cx.shadowBlur=dotR*4;
    cx.beginPath();cx.arc(cx2,cy2,dotR*2,0,6.283);cx.fill();
    cx.shadowBlur=0;

    // ── Slow rotating spoke lines (3 spokes, react to mids) ──
    let mid=0;
    const mStart=8,mEnd=24;
    for(let i=mStart;i<mEnd&&i<n;i++) mid+=fBuf[i];
    mid=mid/((mEnd-mStart)*255);
    const spokelen=R*(0.35+mid*0.45);
    const rot=frameN*0.012;
    cx.strokeStyle=`rgba(${wR},${wG},${wB},${(0.15+mid*0.35).toFixed(3)})`;
    cx.lineWidth=0.8;
    for(let s=0;s<3;s++){
      const a=rot+s*(Math.PI*2/3);
      cx.beginPath();
      cx.moveTo(cx2,cy2);
      cx.lineTo(cx2+Math.cos(a)*spokelen,cy2+Math.sin(a)*spokelen);
      cx.stroke();
    }

    cx.restore(); // release clip region

    requestAnimationFrame(frame);
  }

  // Auto-resize when panel resizes
  const ro=new ResizeObserver(()=>resize());
  ro.observe(cv);
  resize();
  requestAnimationFrame(frame);
  return {setSoil};
})();
return {
  transport,soil:soilCtrl,groove:grooveCtrl,drop,seq,synth,rec,export:exportFns,help,
  ui,theme,
  init,_pt,_pa,_ps
};

})();
</script>
