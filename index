// ── DROP ───────────────────────────────────────────────
const drop=(()=>{
  function fire(){
    initAudio();if(ctx.state==='suspended')ctx.resume();
    dropActive=true;
    document.getElementById('dropBtn').classList.add('firing');
    document.getElementById('vhudBR').textContent='⚡ DROP INCOMING';
    const now=ctx.currentTime;
    // Pre-drop: filter closes
    if(lpFilter){
      lpFilter.frequency.cancelScheduledValues(now);
      lpFilter.frequency.setValueAtTime(lpFilter.frequency.value,now);
      lpFilter.frequency.exponentialRampToValueAtTime(55,now+.8);
      lpFilter.Q.setValueAtTime(mapRes(P.res)*5,now);
    }
    if(delayFB)delayFB.gain.setValueAtTime(.75,now+.8);
    setTimeout(()=>{
      // Screen shake
      ['mainHdr','mainBody'].forEach(id=>{
        const el=document.getElementById(id);
        if(el){el.classList.add('shake');setTimeout(()=>el.classList.remove('shake'),350);}
      });
      // Impact
      const n=ctx.currentTime;
      if(lpFilter){
        lpFilter.frequency.exponentialRampToValueAtTime(mapCutoff(P.cutoff)*5,n+.025);
        lpFilter.frequency.exponentialRampToValueAtTime(mapCutoff(P.cutoff),n+1.8);
        lpFilter.Q.exponentialRampToValueAtTime(mapRes(P.res),n+1.2);
      }
      // Sub boom
      const bo=ctx.createOscillator(),bg=ctx.createGain();
      bo.type='sine';bo.frequency.setValueAtTime(55,n);bo.frequency.exponentialRampToValueAtTime(28,n+.7);
      bg.gain.setValueAtTime(2,n);bg.gain.exponentialRampToValueAtTime(.001,n+.8);
      bo.connect(bg);bg.connect(masterGain);bo.start(n);bo.stop(n+.85);
    },800);
    setTimeout(()=>{
      seq.randomize();
      if(delayFB)delayFB.gain.value=.22;
      dropActive=false;
      document.getElementById('dropBtn').classList.remove('firing');
      document.getElementById('vhudBR').textContent='';
    },2500);
    if(!playing)transport.start();
  }
  return {fire};
})();

// ── SYNTH CONTROL ──────────────────────────────────────
const synth=(()=>{
  function set(key,val){
    P[key]=parseFloat(val);
    if(!ctx)return;
    if(key==='chaos'){
      // chaos drives mutation rate in autoMutate() via P.chaos
      // also modulate reese wobble depth slightly
      if(reeseModGain)reeseModGain.gain.value=
        ({dnb:280,dubstep:420,acid:480,breaks:180,glitch:150}[groove]||200)
        *(0.5+P.chaos/100*1.0);
    }
    if(key==='cutoff')lpFilter.frequency.value=mapCutoff(P.cutoff);
    if(key==='res')lpFilter.Q.value=mapRes(P.res);
    if(key==='bpFreq')bpFilter.frequency.value=mapCutoff(P.bpFreq);
    if(key==='drive'||key==='fold'||key==='clip')buildDistCurves();
    if(key==='lfo1Rate')lfo1Osc.frequency.value=mapLfoRate(P.lfo1Rate);
    if(key==='lfo1Depth')lfo1Gain.gain.value=mapLfoDepth(P.lfo1Depth)*(P.mod_lfo1_cutoff/100);
    if(key==='lfo2Rate')lfo2Osc.frequency.value=mapLfoRate(P.lfo2Rate);
    if(key==='mod_lfo1_cutoff')lfo1Gain.gain.value=mapLfoDepth(P.lfo1Depth)*(P.mod_lfo1_cutoff/100);
  }
  function setDistType(type){
    const pr={reese:{drive:28,fold:6,clip:5},neuro:{drive:32,fold:38,clip:14},soft:{drive:18,fold:0,clip:3},fold:{drive:22,fold:55,clip:10},fuzz:{drive:65,fold:25,clip:35}};
    const p=pr[type]||pr.reese;
    P.drive=p.drive;P.fold=p.fold;P.clip=p.clip;
    buildDistCurves();
    allKnobs.forEach(k=>{const el=document.getElementById('kv_'+k.key);if(el)el.textContent=Math.round(P[k.key]);k.draw();});
  }
  function setLayer(layer,val){
    layerGains[layer]=val/100;
    if(!ctx)return;
    if(layer==='sub'&&subGainNode)subGainNode.gain.value=layerGains.sub;
    if(layer==='mid'&&midGainNode)midGainNode.gain.value=layerGains.mid;
    if(layer==='top'&&topGainNode)topGainNode.gain.value=layerGains.top;
  }
  return {set,setDistType,setLayer};
})();

// ── RECORDING ──────────────────────────────────────────
const rec=(()=>{
  let recFmt='webm',recDur=0,recQ=256;
  let recActive=false,recStream=null,mediaRec=null,recChunks=[],recTimer=null,recStart=0;

  function openDrawer(){
    document.getElementById('recDrawer').classList.add('open');
    document.getElementById('recDrawer-backdrop').classList.add('open');
    document.getElementById('recMinTab').classList.remove('visible');
  }
  function closeDrawer(){
    if(recActive){ minimiseDrawer(); return; }
    document.getElementById('recDrawer').classList.remove('open');
    document.getElementById('recDrawer-backdrop').classList.remove('open');
    document.getElementById('recMinTab').classList.remove('visible');
  }
  function minimiseDrawer(){
    document.getElementById('recDrawer').classList.remove('open');
    document.getElementById('recDrawer-backdrop').classList.remove('open');
    document.getElementById('recMinTab').classList.add('visible');
  }
  function maximiseDrawer(){
    document.getElementById('recDrawer').classList.add('open');
    document.getElementById('recDrawer-backdrop').classList.add('open');
    document.getElementById('recMinTab').classList.remove('visible');
  }
  const openModal=openDrawer;
  const closeModal=closeDrawer;

  function setFmt(f,btn){recFmt=f;document.querySelectorAll('[data-fmt]').forEach(b=>b.classList.toggle('selected',b.dataset.fmt===f));}
  function setDur(d,btn){recDur=+d;document.querySelectorAll('[data-dur]').forEach(b=>b.classList.toggle('selected',b.dataset.dur==d));}
  function setQ(q,btn){recQ=+q;document.querySelectorAll('[data-q]').forEach(b=>b.classList.toggle('selected',b.dataset.q==q));}

  function toggleRec(){ if(recActive)stopRec();else startRec(); }

  function startRec(){
    initAudio();if(ctx.state==='suspended')ctx.resume();
    const dest=ctx.createMediaStreamDestination();
    masterGain.connect(dest);
    recChunks=[];
    const mimeType='audio/webm;codecs=opus';
    const opts={mimeType,audioBitsPerSecond:recQ*1000};
    try{mediaRec=new MediaRecorder(dest.stream,opts);}
    catch(e){mediaRec=new MediaRecorder(dest.stream);}
    mediaRec.ondataavailable=e=>recChunks.push(e.data);
    mediaRec.onstop=()=>{
      masterGain.disconnect(dest);
      const ext=recFmt==='mp3-sim'?'mp3':recFmt==='wav-sim'?'wav':'webm';
      const blob=new Blob(recChunks,{type:'audio/webm'});
      const a=document.createElement('a');
      a.href=URL.createObjectURL(blob);
      a.download='wormbass_v4_'+getSeed()+'.'+ext;
      a.click();
      recActive=false;
      document.getElementById('recStartBtn').textContent='START RECORDING';
      document.getElementById('recStartBtn').classList.remove('recording');
      document.getElementById('recDot').classList.remove('live');
      document.getElementById('recBtn').classList.remove('rec-live');
      document.getElementById('recHandleDot').classList.remove('live');
      document.getElementById('recMinTab').classList.remove('visible');
      document.getElementById('recStatus').textContent='\u2713 Saved!';
      document.getElementById('recProgFill').style.width='100%';
      maximiseDrawer();
      setTimeout(()=>{
        document.getElementById('recProgFill').style.width='0%';
        document.getElementById('recStatus').textContent='Ready to record';
        document.getElementById('recDrawer').classList.remove('open');
        document.getElementById('recDrawer-backdrop').classList.remove('open');
      },2200);
    };
    mediaRec.start();
    recActive=true; recStart=Date.now();
    document.getElementById('recStartBtn').textContent='\u25a0 STOP RECORDING';
    document.getElementById('recStartBtn').classList.add('recording');
    document.getElementById('recDot').classList.add('live');
    document.getElementById('recBtn').classList.add('rec-live');
    document.getElementById('recHandleDot').classList.add('live');
    document.getElementById('recStatus').textContent='\u25cf Recording\u2026';
    if(!playing)transport.start();
    // Auto-minimise after 1.2s so user can work
    setTimeout(()=>{ if(recActive) minimiseDrawer(); },1200);
    // Timer: auto-stop for bar modes, elapsed counter for free mode
    const durMs=recDur>0?(recDur*(60/bpm)*4*1000):0;
    if(durMs>0){
      const prog=document.getElementById('recProgFill');
      let elapsed=0;
      recTimer=setInterval(()=>{
        elapsed+=200;
        prog.style.width=Math.min(100,(elapsed/durMs)*100)+'%';
        const remaining=Math.ceil((durMs-elapsed)/1000);
        document.getElementById('recStatus').textContent='● REC – '+remaining+'s left';
        if(elapsed>=durMs){clearInterval(recTimer);stopRec();}
      },200);
    } else {
      // FREE mode — tick elapsed time, pulse bar, stop when user presses ■ STOP
      let elapsed=0;
      recTimer=setInterval(()=>{
        elapsed+=100;
        const mins=Math.floor(elapsed/60000);
        const secs=Math.floor((elapsed%60000)/1000);
        const ds=Math.floor((elapsed%1000)/100);
        document.getElementById('recStatus').textContent=
          '● REC '+mins+':'+(secs<10?'0':'')+secs+'.'+ds+'  — press ■ STOP to save';
        document.getElementById('recProgFill').style.width=(30+Math.sin(elapsed/400)*28)+'%';
      },100);
    }
  }

  function stopRec(){
    if(!mediaRec||!recActive)return;
    clearInterval(recTimer);
    mediaRec.stop();
  }

  return {openModal,closeModal,openDrawer,closeDrawer,minimiseDrawer,maximiseDrawer,setFmt,setDur,setQ,toggleRec,startRec,stopRec};
})();

