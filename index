function makeKnob(container,key,label,min,max,color,unit=''){
  const wrap=document.createElement('div');wrap.className='knob-wrap';
  const cvs=document.createElement('canvas');cvs.className='knob-canvas';
  cvs.width=KS;cvs.height=KS;cvs.style.width=KS+'px';cvs.style.height=KS+'px';
  const nm=document.createElement('div');nm.className='kname';nm.textContent=label;
  const vl=document.createElement('div');vl.className='kval';vl.id='kv_'+key;
  vl.textContent=Math.round(P[key])+(unit||'');
  wrap.append(cvs,nm,vl);container.appendChild(wrap);

  const norm=()=>Math.max(0,Math.min(1,(P[key]-min)/(max-min)));
  const draw=()=>{
    const c=cvs.getContext('2d'),cx=KS/2,cy=KS/2,r=cx-5;
    c.clearRect(0,0,KS,KS);
    c.beginPath();c.arc(cx,cy,r,0.75*Math.PI,2.25*Math.PI);
    c.strokeStyle='#141c28';c.lineWidth=3;c.stroke();
    const ang=0.75*Math.PI+norm()*1.5*Math.PI;
    c.beginPath();c.arc(cx,cy,r,0.75*Math.PI,ang);
    c.strokeStyle=color;c.lineWidth=3;c.shadowColor=color;c.shadowBlur=norm()>.4?7:2;c.stroke();
    c.shadowBlur=0;
    const dx=cx+Math.cos(ang)*r,dy=cy+Math.sin(ang)*r;
    c.beginPath();c.arc(dx,dy,2.5,0,Math.PI*2);c.fillStyle='#fff';c.shadowBlur=5;c.shadowColor='#fff';c.fill();c.shadowBlur=0;
  };
  draw();

  let drag=false,sy=0,sv=0;
  cvs.addEventListener('mousedown',e=>{drag=true;sy=e.clientY;sv=P[key];e.preventDefault();});
  window.addEventListener('mousemove',e=>{
    if(!drag)return;
    P[key]=Math.max(min,Math.min(max,sv+(sy-e.clientY)*(max-min)/130));
    vl.textContent=Math.round(P[key])+(unit||'');
    draw();synth.set(key,P[key]);
  });
  window.addEventListener('mouseup',()=>drag=false);
  // Touch drag for mobile
  cvs.addEventListener('touchstart',e=>{drag=true;sy=e.touches[0].clientY;sv=P[key];e.preventDefault();},{passive:false});
  window.addEventListener('touchmove',e=>{
    if(!drag)return;
    e.preventDefault();
    P[key]=Math.max(min,Math.min(max,sv+(sy-e.touches[0].clientY)*(max-min)/130));
    vl.textContent=Math.round(P[key])+(unit||'');
    draw();synth.set(key,P[key]);
  },{passive:false});
  window.addEventListener('touchend',()=>drag=false,{passive:true});
  cvs.addEventListener('dblclick',()=>{const v=prompt(label+' ('+min+'-'+max+')',Math.round(P[key]));if(v!=null&&!isNaN(+v)){P[key]=Math.max(min,Math.min(max,+v));vl.textContent=Math.round(P[key])+(unit||'');draw();synth.set(key,P[key]);}});
  return {draw,key};
}

