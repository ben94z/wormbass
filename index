    for(let o=0;o<6;o++)for(let n=0;n<12;n++)NOTE_MIDI[NOTES[n]+o]=24+o*12+n;
    const tempo=Math.round(60000000/bpm),ppq=96,stk=ppq/4;
    const bytes=[],track=[];
    const pi32=v=>bytes.push((v>>24)&0xff,(v>>16)&0xff,(v>>8)&0xff,v&0xff);
    const pi16=v=>bytes.push((v>>8)&0xff,v&0xff);
    const vl=v=>{const b=[];b.unshift(v&0x7f);v>>=7;while(v>0){b.unshift((v&0x7f)|0x80);v>>=7;}return b;};
    bytes.push(0x4d,0x54,0x68,0x64);pi32(6);pi16(0);pi16(1);pi16(ppq);
    track.push(0x00,0xff,0x51,0x03,(tempo>>16)&0xff,(tempo>>8)&0xff,tempo&0xff);
