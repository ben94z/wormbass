        <div class="splash-worm" style="left:85%;animation-delay:.5s;animation-duration:2.3s"></div>
      </div>
      🪱 <span id="wriggle-label">WRIGGLE</span>
    </button>
    <div class="splash-made">Made by Ben94Z &nbsp;·&nbsp; V3</div>
  </div>
</div>

<!-- ═══════════════ MAIN APP ═══════════════════ -->
<div id="app">

  <!-- HEADER -->
  <div class="hdr" id="mainHdr">
    <!-- ROW 1: main controls -->
    <div class="hdr-row1">
      <div class="hdr-scan"></div>
      <div class="logo" onclick="W.transport.stop()"><span class="logo-w">WORM</span><span class="logo-b">BASS</span><span class="logo-v">V5</span></div>
      <div class="vline"></div>
      <div class="sring" id="sring"></div>
      <button class="tbtn" id="playBtn" data-tip="Start or pause the sequencer" onclick="W.transport.toggle()">▶ PLAY</button>
      <button class="tbtn" data-tip="Stop and reset position" onclick="W.transport.stop()">■ STOP</button>
      <div class="vline"></div>
      <div class="groove-row">
        <button class="gbtn active" data-groove="dnb" data-tip="174 BPM drum & bass Reese groove" onclick="W.groove.set('dnb',this)">D&amp;B</button>
        <button class="gbtn" data-groove="dubstep" data-tip="140 BPM half-time wobble bass" onclick="W.groove.set('dubstep',this)">DUBS</button>
        <button class="gbtn" data-groove="breaks" data-tip="140 BPM funky breakbeat swing" onclick="W.groove.set('breaks',this)">BRKZ</button>
        <button class="gbtn" data-groove="acid" data-tip="132 BPM rolling 303-style acid" onclick="W.groove.set('acid',this)">ACID</button>
        <button class="gbtn" data-groove="glitch" data-tip="150 BPM stuttered glitch chaos" onclick="W.groove.set('glitch',this)">GLCH</button>
      </div>
      <div class="vline"></div>
      <button class="tbtn drop-btn" id="dropBtn" data-tip="Trigger explosive bass drop" onclick="W.drop.fire()">🔥 DROP</button>
      <div class="vline"></div>
      <div class="rec-group">
        <div class="rec-dot" id="recDot"></div>
        <button class="tbtn" id="recBtn" data-tip="Open recording options" onclick="W.rec.openModal()">⏺ REC</button>
      </div>
      <div style="margin-left:auto;display:flex;gap:4px;align-items:center;flex-shrink:0;">
        <button class="tbtn" data-tip="View instructions and controls guide" onclick="W.help.open()" style="border-color:var(--acid);color:var(--acid);">?</button>
        <button class="tbtn" data-tip="Change UI colour theme" onclick="W.theme.toggle()" style="border-color:var(--pur);color:var(--pur);">🎨</button>
      </div>
    </div>
    <!-- ROW 2: tempo controls — always fully visible -->
    <div class="hdr-row2">
      <div class="bpm-wrap">
        <span class="bpm-lbl">BPM</span>
        <button class="bpm-arrow" data-tip="BPM -5" onclick="W.transport.changeBpm(-5)">«</button>
        <button class="bpm-arrow" onclick="W.transport.changeBpm(-1)">‹</button>
        <span class="bpm-num" id="bpmNum">174</span>
        <button class="bpm-arrow" onclick="W.transport.changeBpm(1)">›</button>
        <button class="bpm-arrow" data-tip="BPM +5" onclick="W.transport.changeBpm(5)">»</button>
      </div>
      <div class="vline"></div>
      <div class="sw-wrap">
        <span class="sw-lbl">SWING</span>
        <input type="range" id="swingSlider" min="0" max="60" value="12" style="width:80px" oninput="W.transport.setSwing(this.value)">
        <span class="sw-num" id="swingNum">12%</span>
      </div>
      <div class="vline"></div>
      <div class="sw-wrap" data-tip="Mutation level — how much the pattern is evolving. Driven by the CHAOS knob." style="border-color:var(--acid)">
        <span class="sw-lbl" style="color:var(--acid)">MUT</span>
        <div style="width:65px;height:3px;background:var(--brd);border-radius:2px;overflow:hidden;position:relative;">
          <div id="mutationMeter2" style="height:100%;width:0%;background:var(--acid);transition:width .4s;box-shadow:0 0 5px var(--acid);border-radius:2px;"></div>
        </div>
        <span id="vhudBL" style="color:var(--acid);letter-spacing:.06em;font-size:.52rem;min-width:28px;"></span>
      </div>
    </div>
  </div>

  <!-- BODY -->
  <div class="body-wrap" id="mainBody">

    <!-- PANELS ROW: [VIZ | Soil+Mix | Osc+Env | Filter+Dist | LFO+Mod+Matrix] -->
    <div class="panels-row">

      <!-- VIZ COL: slim worm column -->
      <div class="viz-wrap">
        <canvas id="vizCanvas"></canvas>
        <span id="vhudTL" style="display:none"></span>
        <span id="vhudTR" style="display:none"></span>
        <span id="vhudBR" style="display:none"></span>
      </div>

      <!-- COL 1: Soil Mode + Layer Mix + New Pattern -->
      <div class="panel">
        <div class="ptitle">Soil Mode</div>
        <div class="soil-grid">
          <button class="soil-btn active" data-soil="dirt"  data-tip="A minor — dark, warm bass" onclick="W.soil.set('dirt',this)">DIRT</button>
          <button class="soil-btn"        data-soil="metal" data-tip="Phrygian — industrial, grinding" onclick="W.soil.set('metal',this)">METAL</button>
          <button class="soil-btn"        data-soil="flesh" data-tip="Dorian — funky, organic, melodic" onclick="W.soil.set('flesh',this)">FLESH</button>
          <button class="soil-btn"        data-soil="void"  data-tip="Minor pentatonic — deep, mysterious" onclick="W.soil.set('void',this)">VOID</button>
        </div>
        <div class="ptitle" style="margin-top:4px">Layer Mix</div>
        <div class="layer-row" id="layerMix"></div>
        <button class="rbtn" style="margin-top:8px;padding:6px 4px;font-size:.58rem" data-tip="Generate a new randomized bassline" onclick="W.seq.randomize()">🎲 NEW PATTERN</button>
        <!-- Circular wire frequency visualizer -->
        <div class="circ-wrap">
          <canvas id="circCanvas"></canvas>
