      <div class="panel">
        <div class="sec-hdr">
          <span class="sec-lbl">Oscillator</span>
          <div class="sec-acts"><button class="smbtn" data-tip="Randomize oscillator knobs" onclick="W.ui.rnd('osc')">RND</button><button class="smbtn rst" data-tip="Reset oscillator to defaults" onclick="W.ui.rst('osc')">RST</button></div>
        </div>
        <div class="knob-grid" id="oscKnobs"></div>
        <div class="sec-hdr" style="margin-top:6px">
          <span class="sec-lbl">Envelope</span>
          <div class="sec-acts"><button class="smbtn" data-tip="Randomize envelope" onclick="W.ui.rnd('env')">RND</button><button class="smbtn rst" data-tip="Reset envelope" onclick="W.ui.rst('env')">RST</button></div>
        </div>
        <div class="knob-grid" id="envKnobs"></div>
      </div>

      <!-- COL 3: Filter + Distortion + Dist Type -->
      <div class="panel">
        <div class="sec-hdr">
          <span class="sec-lbl">Filter</span>
          <div class="sec-acts"><button class="smbtn" data-tip="Randomize filter" onclick="W.ui.rnd('filter')">RND</button><button class="smbtn rst" data-tip="Reset filter" onclick="W.ui.rst('filter')">RST</button></div>
        </div>
        <div class="knob-grid" id="filterKnobs"></div>
        <div class="sec-hdr" style="margin-top:6px">
          <span class="sec-lbl">Distortion</span>
          <div class="sec-acts"><button class="smbtn" data-tip="Randomize distortion" onclick="W.ui.rnd('dist')">RND</button><button class="smbtn rst" data-tip="Reset distortion" onclick="W.ui.rst('dist')">RST</button></div>
        </div>
