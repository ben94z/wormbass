//  DEATH WORM VISUALISER V5 — Nyan-Cat Death Worm
// ═══════════════════════════════════════════════════════
const VIZ=(()=>{
// ─────────────────────────────────────────────────────
//  WORM DISPLAY — minimal 2D vector glow worm
//  No soil, no trail ring, no GC. Pure snake line.
//  Target: <1ms per frame on any device
// ─────────────────────────────────────────────────────
  const cv=document.getElementById('vizCanvas');
  const cx=cv.getContext('2d',{alpha:false});
  let W=0,H=0;

  // Typed arrays — zero allocation in hot path
  const NS=36;
  const sx=new Float32Array(NS), sy=new Float32Array(NS);
  let hx=0,hy=0,dir=1,spd=0,ft=0,rdy=false;

  // Audio smoothed bands
  let fA=null,eBass=0,eMid=0,eHigh=0,eKick=0,prev=0,kH=0;

  // Worm colour (RGB ints, updated by setSoil)
  let wR=0,wG=255,wB=136;

  function resize(){
    const ow=cv.offsetWidth,oh=cv.offsetHeight;
    if(!ow||!oh)return;
    W=ow;H=oh;cv.width=W;cv.height=H;
    const n=analyser?analyser.frequencyBinCount:64;
    fA=new Uint8Array(n);
    if(!rdy){hx=W*.2;hy=H*.5;for(let i=0;i<NS;i++){sx[i]=hx-i*12;sy[i]=hy;}rdy=true;}
  }

  function setSoil(s){
    const cfg=(typeof SOIL_CFG!=='undefined'&&SOIL_CFG[s])||{color:'#00ff88'};
    const x=(cfg.color||'#00ff88').replace('#','');
    wR=parseInt(x.slice(0,2),16);wG=parseInt(x.slice(2,4),16);wB=parseInt(x.slice(4,6),16);
  }

  function readAudio(){
    if(!analyser||!fA)return;
    analyser.getByteFrequencyData(fA);
    let b=0,m=0,hi=0;
    for(let i=0;i<4;i++)b+=fA[i];
    for(let i=4;i<20;i++)m+=fA[i];
    for(let i=20;i<55&&i<fA.length;i++)hi+=fA[i];
    const rB=b/(4*255),rM=m/(16*255),rH=hi/(35*255);
    eBass=eBass*.76+rB*.24; eMid=eMid*.82+rM*.18; eHigh=eHigh*.88+rH*.12;
    if(rB>.44&&prev<.34){eKick=Math.min(1,rB*1.7);kH=6;}
    if(kH>0)kH--;else eKick*=.82;
    prev=rB;
  }

  function move(){
    ft++;
    const ts=playing?(0.6+eBass*3+eKick*2.5):0;
    spd=spd*.88+ts*.12;
    hx+=dir*spd; if(hx>W-10){dir=-1;hx=W-10;} if(hx<10){dir=1;hx=10;}
    // Y: three freq bands drive independent sine waves
    const cy=H*.5;
    const yB=Math.sin(ft*.030)*H*(.35+eBass*.18);
    const yM=Math.sin(ft*.062)*H*(.12+eMid*.10);
    const yH=Math.sin(ft*.170)*H*(.03+eHigh*.04);
    const yK=eKick*H*.15;
    hy+=(cy+yB+yM+yH+yK-hy)*.14;
    sx[0]=hx;sy[0]=hy;
    for(let i=1;i<NS;i++){sx[i]+=(sx[i-1]-sx[i])*.36;sy[i]+=(sy[i-1]-sy[i])*.36;}
  }

  function draw(){
    // Always clear canvas
    cx.fillStyle='#02040a';
    cx.fillRect(0,0,W,H);

    // If not playing — worm is invisible, just show dark canvas
    if(!playing||!rdy){cx.globalAlpha=1;return;}

    cx.lineCap='round';cx.lineJoin='round';

    // ── Outer glow pass ──
    cx.globalAlpha=.22+eBass*.18;
    cx.strokeStyle=`rgb(${wR},${wG},${wB})`;
    cx.lineWidth=8+eBass*10+eKick*6;
    cx.shadowColor=`rgb(${wR},${wG},${wB})`;
    cx.shadowBlur=18+eBass*20+eKick*14;
    cx.beginPath();cx.moveTo(sx[0],sy[0]);
    for(let i=1;i<NS;i++)cx.lineTo(sx[i],sy[i]);
    cx.stroke();cx.shadowBlur=0;

    // ── Mid glow ──
    cx.globalAlpha=.55+eMid*.20;
    cx.lineWidth=4+eBass*6+eKick*4;
    cx.shadowBlur=8+eBass*10;
    cx.beginPath();cx.moveTo(sx[0],sy[0]);
    for(let i=1;i<NS;i++)cx.lineTo(sx[i],sy[i]);
    cx.stroke();cx.shadowBlur=0;

    // ── Core bright line ──
    cx.globalAlpha=.90+eHigh*.10;
    cx.strokeStyle=`hsl(145,100%,${(52+eBass*20+eHigh*15)|0}%)`;
    cx.lineWidth=1.8+eBass*2;
    cx.beginPath();cx.moveTo(sx[0],sy[0]);
    for(let i=1;i<NS;i++)cx.lineTo(sx[i],sy[i]);
    cx.stroke();

    // ── Head glow ──
    const hr=5+eBass*7+eKick*5;
    const hgrd=cx.createRadialGradient(sx[0],sy[0],0,sx[0],sy[0],Math.max(.1,hr*2.2));
    hgrd.addColorStop(0,'rgba(255,255,255,.9)');
    hgrd.addColorStop(.2,`rgba(${wR},${wG},${wB},.95)`);
    hgrd.addColorStop(1,'rgba(0,0,0,0)');
    cx.fillStyle=hgrd;
    cx.shadowColor=`rgb(${wR},${wG},${wB})`;
    cx.shadowBlur=hr*(16+eKick*10);
    cx.globalAlpha=1;
    cx.beginPath();cx.arc(sx[0],sy[0],hr*2.2,0,6.283);cx.fill();
    cx.shadowBlur=0;

    // ── Eyes ──
    const s1=Math.min(3,NS-1);
    const ang=Math.atan2(sy[0]-sy[s1],sx[0]-sx[s1]);
    const eo=hr*.9;
    [1,-1].forEach(side=>{
      const ex=sx[0]+Math.cos(ang+side*1.5708)*eo;
      const ey=sy[0]+Math.sin(ang+side*1.5708)*eo;
      if(!isFinite(ex))return;
      cx.fillStyle=`rgb(${wR},${wG},${wB})`;
      cx.shadowColor=`rgb(${wR},${wG},${wB})`;cx.shadowBlur=4+eKick*5;
      cx.globalAlpha=.85+eHigh*.15;
      cx.beginPath();cx.arc(ex,ey,2+eKick*1.5,0,6.283);cx.fill();
      cx.shadowBlur=0;cx.globalAlpha=1;
    });

    cx.globalAlpha=1;
  }

  function frame(){
    if(!W||!H){resize();requestAnimationFrame(frame);return;}
    readAudio();move();draw();
    requestAnimationFrame(frame);
  }

  setSoil('dirt');
  requestAnimationFrame(()=>{resize();frame();});
  window.addEventListener('resize',resize);
  return {setSoil};
})();

